{
  "name": "hyperos-design-system",
  "version": "0.0.2",
  "private": true,
  "scripts": {
    "dev": "TINA_PUBLIC_IS_LOCAL=true tinacms dev -c \"next dev\"",
    "build": "tinacms build && next build",
    "start": "next start",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "tina:build": "tinacms build",
    "tina:dev": "TINA_PUBLIC_IS_LOCAL=true tinacms dev -c \"next dev\"",
    "icons:sync": "node scripts/generate-icon-manifest.mjs",
    "icons:import": "node scripts/generate-icon-manifest.mjs --import-from",
    "tokens:import": "node scripts/import-os4-tokens.mjs"
  },
  "dependencies": {
    "@icons-pack/react-simple-icons": "^13.11.1",
    "cnfast": "^0.0.8",
    "fumadocs-core": "16.11.1",
    "fumadocs-mdx": "15.1.0",
    "fumadocs-ui": "npm:@fumadocs/base-ui@16.11.1",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tinacms": "^3.10.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@tinacms/cli": "^2.5.3",
    "@tinacms/datalayer": "^2.0.27",
    "@types/mdx": "^2.0.14",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3"
  }
}
