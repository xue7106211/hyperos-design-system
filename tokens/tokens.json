{
  "$name": "HyperOS Design Tokens",
  "color": {
    "brand": {
      "primary": {
        "$type": "color",
        "$value": "#007AFF",
        "$description": "HyperOS 品牌主色"
      },
      "primary-hover": {
        "$type": "color",
        "$value": "#0066DD",
        "$description": "主色悬停态"
      }
    },
    "action": {
      "primary-bg": {
        "$type": "color",
        "$value": "{color.brand.primary}",
        "$description": "主要操作按钮背景"
      },
      "primary-fg": {
        "$type": "color",
        "$value": "#FFFFFF",
        "$description": "主要操作按钮文字"
      },
      "secondary-bg": {
        "$type": "color",
        "$value": "#F0F0F0",
        "$description": "次要操作按钮背景"
      },
      "secondary-fg": {
        "$type": "color",
        "$value": "#1A1A1A",
        "$description": "次要操作按钮文字"
      }
    },
    "surface": {
      "background": {
        "$type": "color",
        "$value": "#FFFFFF",
        "$description": "页面背景"
      },
      "elevated": {
        "$type": "color",
        "$value": "#F7F7F7",
        "$description": "卡片/浮层背景"
      }
    },
    "text": {
      "primary": {
        "$type": "color",
        "$value": "#1A1A1A",
        "$description": "主要文字"
      },
      "secondary": {
        "$type": "color",
        "$value": "#666666",
        "$description": "次要文字"
      }
    }
  },
  "spacing": {
    "button": {
      "padding-x": {
        "$type": "dimension",
        "$value": "16px",
        "$description": "按钮水平内边距"
      },
      "padding-y": {
        "$type": "dimension",
        "$value": "10px",
        "$description": "按钮垂直内边距"
      },
      "gap": {
        "$type": "dimension",
        "$value": "8px",
        "$description": "按钮图标与文字间距"
      }
    },
    "scale": {
      "2": {
        "$type": "dimension",
        "$value": "2px"
      },
      "4": {
        "$type": "dimension",
        "$value": "4px"
      },
      "8": {
        "$type": "dimension",
        "$value": "8px"
      },
      "12": {
        "$type": "dimension",
        "$value": "12px"
      },
      "16": {
        "$type": "dimension",
        "$value": "16px"
      },
      "24": {
        "$type": "dimension",
        "$value": "24px"
      }
    }
  },
  "typography": {
    "button": {
      "label": {
        "$type": "dimension",
        "$value": "16px",
        "$description": "按钮标签字号"
      }
    }
  }
